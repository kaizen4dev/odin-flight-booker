<h1>Book a flight</h1>
<%= form_with model: @booking do |f|%>
  <% flight = Flight.find params[:flight_id] %>
  <%= f.text_field :flight_id, value: flight.id, hidden: true%>
  <p>From: <%= flight.departure_airport.code %> </p>
  <p>To: <%= flight.arrival_airport.code %> </p>
  <p>Date: <%= flight.start.strftime("%Y-%m-%d, %H:%M") %> </p>
  <p>Duration: <%= flight.duration %> </p>
  <p>Passengers:</p>
  <div data-controller="passengers">
  <%= f.fields_for :passengers do |p|%>
    <div data-controller="passenger-inputs" data-passenger-inputs-index-value="<%= p.index %>">
      <div>
        <%= p.label :name %>
        <%= p.text_field :name %>
      </div>
      <div>
        <%= p.label :email %>
        <%= p.email_field :email %>
      </div>
      <%= button_tag "Remove Passenger", type: "button", "data-action": "passenger-inputs#removed"%>
      <hr>
    </div>
  <% end %>
  </div>
  <%= f.submit %>
<% end %>

<template id="add-passenger-button-template">
  <button name="button" type="button" data-action="passenger-inputs#added">Add Passenger</button>
  <hr>
</template>

<template id="passenger-inputs-template">
  <div>
    <label data-passenger-inputs-target="nameLabel">Name</label>
    <input type="text" data-passenger-inputs-target="nameInput">
  </div>
  <div>
    <label data-passenger-inputs-target="emailLabel">Email</label>
    <input type="email" data-passenger-inputs-target="emailInput">
  </div>
  <button name="button" type="button" data-action="passenger-inputs#removed">Remove Passenger</button>
  <hr>
</template>
